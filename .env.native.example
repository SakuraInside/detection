# Скопируйте в .env.native и раскомментируйте при необходимости.
# start_ui.sh подхватывает .env.native (set -a source).

# Не поднимать integra-alarmd (только веб-интерфейс)
# INTEGRA_START_ALARMD=0

# Порт приёма тревог от native integra-pipeline
# INTEGRA_ALARMD_LISTEN=127.0.0.1:9090

# Явные корни SDK (если не лежат в ~/Downloads)
# TENSORRT_ROOT=/path/to/TensorRT-x.y
# INTEGRA_ONNXRUNTIME_ROOT=/path/to/onnxruntime-linux-x64-gpu-x.y.z
