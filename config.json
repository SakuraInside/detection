{
  "model": {
    "weights": "models/yolo11s.pt",
    "imgsz": 960,
    "device": "cuda:0",
    "half": true,
    "conf": 0.35,
    "iou": 0.40,

    "person_class": 0,
    "object_classes": [],

    "detect_object_conf": 0.35,

    "_comment_detect_object_classes": "COCO-id оставляемых предметов (по умолчанию: backpack/handbag/suitcase/bottle/cup/bowl/laptop/phone/book...). Можно переопределить ключом detect_object_classes; пустой [] отключит YOLO-источник.",

    "min_box_size_px": 22,
    "use_native_regional_conf": true,
    "person_min_conf_border": 0.33,
    "upper_region_y_ratio": 0.62,
    "min_conf_upper": 0.32,
    "min_conf_lower": 0.32,
    "bottom_region_y_ratio": 0.88,
    "min_conf_bottom": 0.32,
    "border_relax_px": 24,
    "min_conf_border": 0.32,
    "class_min_conf": {
      "person": 0.33
    },

    "tracker": {
      "type": "bytetrack",
      "high_thresh": 0.40,
      "low_thresh": 0.10,
      "new_thresh": 0.50,
      "match_thresh": 0.80,
      "track_buffer": 30
    },

    "use_inference_worker": true,
    "worker_queue_size": 4,
    "worker_timeout_sec": 20.0,
    "worker_startup_timeout_sec": 90.0,
    "worker_mp_start_method": "spawn",
    "worker_use_shared_memory": true,
    "inference_rpc_addr": "",
    "inference_rpc_timeout_sec": 20.0
  },
  "pipeline": {
    "decode_queue": 1,
    "result_queue": 1,
    "detect_every_n_frames": 1,
    "target_fps": 30,
    "render_overlay": true,
    "prefer_hw_decode": false,
    "jpeg_quality": 70,
    "render_every_n_frames": 1,
    "preview_max_long_edge": 1280,
    "preview_jpeg_quality": 92,
    "preview_min_interval_ms": 33,
    "preview_skip_redundant_enqueue": true,
    "frame_pool_size": 4,
    "snapshot_max_long_edge": 480,
    "snapshot_jpeg_quality": 70,
    "rust_video_bridge_addr": "",
    "runtime_core_addr": "",
    "runtime_core_timeout_sec": 0.05,
    "runtime_control_addr": "",
    "runtime_control_timeout_sec": 0.01,
    "forensic_ring_max": 0,
    "memory_chart_warning_bytes": 419430400,
    "memory_chart_critical_bytes": 524288000,
    "preview_encode_max_fps": 25,
    "analytics_extra_pids": []
  },
  "analyzer": {
    "track_only_persons": true,

    "static_displacement_px": 7,
    "static_window_sec": 3.0,
    "abandon_time_sec": 15.0,
    "owner_proximity_px": 180,
    "owner_left_sec": 5.0,
    "disappear_grace_sec": 4.0,
    "min_object_area_px": 400,
    "ignore_detection_norm_rect": [0.52, 0.12, 0.99, 0.88],

    "tracker_iou_match_threshold": 0.12,
    "tracker_max_missed_frames": 45,
    "tracker_soft_centroid_match": 1,

    "max_object_area_ratio": 0.0,
    "suppress_lost_person_frames": 20,

    "use_frame_diff_detector": true,
    "frame_diff_buffer_size": 10,
    "frame_diff_pixel_threshold": 20.0,
    "frame_diff_gradient_threshold": 15.0,
    "frame_diff_min_region_area_px": 60
  },
  "native_analytics": {
    "enabled": true,
    "addr": "127.0.0.1:9909",
    "timeout_sec": 4.0,
    "fallback_to_python": true,
    "engine": "opencv",
    "model_path": "models/yolo11s.onnx",
    "input_size": 960,
    "require_real_engine": true
  },
  "ui": {
    "alarm_sound": true,
    "show_persons": true,
    "show_track_ids": true,
    "show_labels": false
  }
}
